{
  "name": "google-practice-lab",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "generate:content": "node scripts/generate-catalog.mjs",
    "refresh:java-api": "node scripts/generate-java21-api.mjs",
    "predev": "npm run generate:content",
    "dev": "vite",
    "prebuild": "npm run generate:content",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --pretty false",
    "test": "vitest run",
    "test:watch": "vitest",
    "verify": "npm run verify:algoviz && npm run verify:java-api && npm run typecheck && npm test && npm run verify:runner && npm run build",
    "verify:algoviz": "node scripts/verify-algoviz.mjs",
    "verify:java-api": "node scripts/verify-java-api.mjs",
    "verify:runner": "npm run generate:content && node scripts/verify-runner.mjs",
    "verify:wandbox": "npm run generate:content && node scripts/verify-runner.mjs --wandbox"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.0",
    "@codemirror/commands": "^6.10.0",
    "@codemirror/lang-java": "^6.0.2",
    "@codemirror/language": "^6.12.1",
    "@codemirror/lint": "^6.9.2",
    "@codemirror/search": "^6.5.11",
    "@codemirror/state": "^6.5.2",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.38.6",
    "@lezer/highlight": "^1.2.3",
    "codemirror": "^6.0.2",
    "d3": "^7.9.0",
    "katex": "^0.16.22",
    "lucide-react": "^0.468.0",
    "mermaid": "^11.16.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^4.12.2",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^7.0.0",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/d3": "^7.4.3",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.1.1",
    "axe-core": "^4.12.1",
    "jsdom": "^29.1.1",
    "typescript": "^5.9.3",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  }
}
